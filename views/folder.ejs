<!DOCTYPE html>

<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>cloud @ sungsoos.kr</title>

        <style>
            /* Pretendard 폰트 적용 */
            @font-face {
                font-family: 'Pretendard Variable';
                font-weight: 45 920;
                font-style: normal;
                font-display: swap;
                src: url('/PretendardVariable.woff2') format('woff2-variations');
            }
            * { font-family: 'Pretendard Variable' !important; scrollbar-width: thin}

            body {
                background: #111;
                color: white;
                font-family: Arial;
                padding: 40px;
            }

            a {
                color: #fff;
                text-decoration: none;
            }

            ul {
                list-style: none;
                padding: 0;
            }

            .folder {
                background: #1c1c1c;
                padding: 10px;
                margin-bottom: 10px;
                border-radius: 6px;
                display: flex;
                align-items: center;
            }

            .folder:hover {
                background: #2a2a2a;
            }

            .icon {
                filter: invert();
                margin-right: 10px;
            }
        </style>
    </head>
    <body>

        <h1>cloud @ sungsoos.kr</h1>
        <h2>/</h2>

        <ul>
            <% folders.forEach(folder => { %>
            <li>
                <a class="folder" href="/<%= folder.name %>">
                    <img src="/folder.svg" alt="folder" height="20" width="20" class="icon"><%= folder.name %>
                </a>
            </li>
            <% }) %>
        </ul>

        <p>
            <a href="/stats">Stats</a>
        </p>
    </body>
</html>